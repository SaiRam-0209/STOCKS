# Angel One SmartAPI Credentials
# Get these from: https://smartapi.angelbroking.com/
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_trading_password_here
ANGEL_TOTP_SECRET=your_totp_base32_secret_here

# Telegram Alerts (optional)
# 1. Message @BotFather on Telegram → /newbot → get token
# 2. Message your bot, then visit: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
